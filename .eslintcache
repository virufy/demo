fig.ts",["418"],"export default {\n  onUpdate: (registration: ServiceWorkerRegistration) => {\n    // eslint-disable-next-line no-restricted-globals, no-alert\n    const shouldReload = confirm('A new version is available. Do you want to update?');\n    if (shouldReload) {\n      registration.unregister().then(() => {\n        window.location.replace(process.env.PUBLIC_URL);\n      });\n    }\n  },\n  onSuccess: (registration: ServiceWorkerRegistration) => {\n    console.info('service worker on success state');\n    console.log(registration);\n  },\n};\n","/Users/josephgaynor/Documents/Work/work_projects/demo/src/locales/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/theme/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/containers/App/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/containers/App/App.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/containers/Welcome/style.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/containers/Welcome/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/containers/Welcome/Welcome.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/containers/App/style.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/containers/Welcome/Step4/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/containers/Welcome/Step4/Step4.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/containers/Welcome/Step3/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/containers/Welcome/Step3/Step3.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/containers/Welcome/Step2/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/containers/Welcome/Step2/Step2.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/containers/Welcome/Step1/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/cont