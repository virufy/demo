as File;\n};\n\nexport default {\n  sizeAsHuman,\n  blobToFile,\n};\n","/Users/josephgaynor/Documents/Work/work_projects/demo/src/helper/getDuration.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Wizard/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/DotIndicators/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/LinkPurple/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Header/Header.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/FooterInstallAsApp/FooterInstallAsApp.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/FooterReportProblems/FooterReportProblems.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Link/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/SetResult/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/WizardButtons/index.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Dropdown/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/CreatedBy/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Texts/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/MicRecorder/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Wizard/Wizard.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/DotIndicators/DotIndicators.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Header/style.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/FooterInstallAsApp/style.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/FooterReportProblems/style.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/LinkPurple/Link.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Link/Link.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/WizardButtons/WizardButtons.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/SetResult/SetResult.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Dropdown/Dropdown.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/CreatedBy/CreatedBy.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Texts/Texts.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/MicRecorder/MicRecorder.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Wizard/style.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/DotIndicators/style.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/data/reportProblemForm.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/hooks/usePWAHelpers.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/LinkPurple/style.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Link/style.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/WizardButtons/style.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/SetResult/style.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Dropdown/style.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/CreatedBy/style.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/modals/PWAInstallModal.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/MicRecorder/style.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/FullWidthDiv/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/modals/style.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/helper/audio/RecorderService.js",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Layout/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/FullWidthDiv/FullWidthDiv.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Button/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/helper/audio/encoder-flac-worker.js",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/helper/audio/encoder-mp3-worker.js",["420"],"/* eslint-disable func-names */\n// import 'babel-polyfill'\n// import lamejs from 'lamejs';\n\nexport default function () {\n  // Note that relative paths don't work when loaded as a blob\n  // https://stackoverflow.com/questions/22172426/using-importsscripts-within-blob-in-a-karma-environment\n  // importScripts('https://localhost:8443/workers/encoders/lame.js') // eslint-disable-line\n\n  const channels = 1; // 1 for mono or 2 for stereo\n  // let sampleRate = 44100 // 44.1khz (normal mp3 samplerate)\n  const kbps = 128; // encode 128kbps mp3\n\n  let mp3encoder = null;\n\n  const maxSamples = 1152;\n\n  let mp3Data = []; // array of Uint8Array\n\n  function init(opts) {\n    /* global lamejs */\n    importScripts(opts.baseUrl + '/workers/encoders/lame.min.js'); // eslint-disable-line\n    mp3encoder = new lamejs.Mp3Encoder(channels, opts.sampleRate, kbps);\n  }\n\n  function floatTo16BitPCM(input, output) {\n    for (let i = 0; i < input.length; i += 1) {\n      const s = Math.max(-1, Math.min(1, input[i]));\n      // eslint-disable-next-line no-param-reassign\n      output[i] = (s < 0 ? s * 0x8000 : s * 0x7FFF);\n    }\n  }\n\n  function convertBuffer(arrayBuffer) {\n    const data = new Float32Array(arrayBuffer);\n    const out = new Int16Array(arrayBuffer.length);\n    floatTo16BitPCM(data, out);\n    return out;\n  }\n\n  function encode(arrayBuffer) {\n    const samplesMono = convertBuffer(arrayBuffer);\n    let remaining = samplesMono.length;\n    for (let i = 0; remaining >= 0; i += maxSamples) {\n      const left = samplesMono.subarray(i, i + maxSamples);\n      const data = mp3encoder.encodeBuffer(left);\n      mp3Data.push(data);\n      remaining -= maxSamples;\n    }\n\n    // var mp3buf = mp3encoder.encodeBuffer(buffer)\n    // if (mp3buf.length > 0) {\n    //   mp3Data.push(mp3buf)\n    // }\n  }\n\n  function dump() {\n    const mp3buf = mp3encoder.flush();\n    if (mp3buf.length > 0) {\n      mp3Data.push(mp3buf);\n    }\n\n    // Probably results in native memory copy\n    postMessage(mp3Data);\n\n    // Would like to do this, but not possible because mp3Data is generic array of Uint8Array, and generic\n    // arrays are not transferrable types.\n    // postMessage(mp3Data, [mp3Data])\n\n    // This might help if/when ever become available again\n    // https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/SharedArrayBuffer\n    // https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/ArrayBuffer/transfer\n\n    // For now, though, we have not other option except to build a complete copy in javascript. This means\n    // we temporarily require twice the memory of whatever was recorded.\n\n    mp3Data = [];\n  }\n\n  onmessage = function onmessage(e) {\n    if (e.data[0] === 'encode') {\n      encode(e.data[1]);\n    } else if (e.data[0] === 'dump') {\n      dump(e.data[1]);\n    } else if (e.data[0] === 'init') {\n      init(e.data[1]);\n    } else if (e.data[0] === 'close') {\n      this.close();\n    }\n  };\n}\n","/Users/josephgaynor/Documents/Work/work_projects/demo/src/helper/audio/encoder-wav-worker.js",["421"],"/* eslint-disable func-names */\nexport default function () {\n  // Parts copied from https://github.com/chris-rudmin/Recorderjs\n  const BYTES_PER_SAMPLE = 2;\n  const CHANNELS = 1; // 1=mono , 2=Stereo\n  let recorded = [];\n\n  function encode(buffer) {\n    const { length } = buffer;\n    const data = new Uint8Array(length * BYTES_PER_SAMPLE * CHANNELS);\n    for (let i = 0; i < length; i += 1) {\n      const index = i * BYTES_PER_SAMPLE * CHANNELS;\n      let sample = buffer[i];\n      if (sample > 1) {\n        sample = 1;\n      } else if (sample < -1) {\n        sample = -1;\n      }\n      sample *= 32768;\n      data[index] = sample;\n      // eslint-disable-next-line no-bitwise\n      data[index + 1] = sample >> 8;\n    }\n    recorded.push(data);\n  }\n\n  function dump(sampleRate) {\n    const bufferLength = recorded.length ? recorded[0].length : 0;\n    const length = recorded.length * bufferLength;\n    const wav = new Uint8Array(44 + length);\n\n    const view = new DataView(wav.buffer);\n\n    // RIFF identifier 'RIFF'\n    view.setUint32(0, 1380533830, false);\n    // file length minus RIFF identifier length and file description length\n    view.setUint32(4, 36 + length, true);\n    // RIFF type 'WAVE'\n    view.setUint32(8, 1463899717, false);\n    // format chunk identifier 'fmt '\n    view.setUint32(12, 1718449184, false);\n    // format chunk length\n    view.setUint32(16, 16, true);\n    // sample format (raw)\n    view.setUint16(20, 1, true);\n    // channel count\n    view.setUint16(22, CHANNELS, true);\n    // sample rate\n    view.setUint32(24, sampleRate, true); // 44100 Khz\n    // byte rate (channels * sample rate * block align)\n    view.setUint32(28, CHANNELS * sampleRate * BYTES_PER_SAMPLE, true); // kbps = 1411\n    // block align (channel count * bytes per sample)\n    view.setUint16(32, CHANNELS * BYTES_PER_SAMPLE, true);\n    // bits per sample\n    view.setUint16(34, 8 * BYTES_PER_SAMPLE, true); // 16\n    // data chunk identifier 'data'\n    view.setUint32(36, 1684108385, false);\n    // data chunk length\n    view.setUint32(40, length, true);\n\n    for (let i = 0; i < recorded.length; i += 1) {\n      wav.set(recorded[i], i * bufferLength + 44);\n    }\n\n    recorded = [];\n    const msg = [wav.buffer];\n    postMessage(msg, [msg[0]]);\n  }\n\n  this.onmessage = e => {\n    if (e.data[0] === 'encode') {\n      encode(e.data[1]);\n    } else if (e.data[0] === 'dump') {\n      dump(e.data[1]);\n    } else if (e.data[0] === 'close') {\n      this.close();\n    }\n  };\n}\n","/Users/josephgaynor/Documents/Work/work_projects/demo/src/modals/RecordErrorModal/index.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Layout/Layout.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Button/Button.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/components/Button/style.ts",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/modals/RecordErrorModal/RecordErrorModal.tsx",[],"/Users/josephgaynor/Documents/Work/work_projects/demo/src/modals/RecordErrorModal/style.ts",[],{"ruleId":"422","severity":1,"message":"423","line":1,"column":1,"nodeType":"424","endLine":15,"endColumn":3},{"ruleId":"422","severity":1,"message":"423","line":30,"column":1,"nodeType":"424","endLine":33,"endColumn":3},{"ruleId":"422","severity":1,"message":"425","line":5,"column":1,"nodeType":"424","endLine":91,"endColumn":2},{"ruleId":"422","severity":1,"message":"425","line":2,"column":1,"nodeType":"424","endLine":79,"endColumn":2},"import/no-anonymous-default-export","Assign object to a variable before exporting as module default","ExportDefaultDeclaration","Unexpected default export of anonymous function"]